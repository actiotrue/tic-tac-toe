{
  "name": "vue-project",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "prepare": "husky"
  },
  "dependencies": {
    "@cloudinary/url-gen": "^1.22.0",
    "@cloudinary/vue": "^1.13.4",
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@tailwindcss/vite": "^4.2.1",
    "@vee-validate/zod": "^4.15.1",
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.1",
    "uuidv7": "^1.1.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.29",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.3",
    "vue3-toastify": "^0.2.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.3",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-vue": "~10.7.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --fix"
  }
}
